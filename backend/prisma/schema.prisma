generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Registration {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  createdAt DateTime @default(now())
  
  @@map("registrations")
}